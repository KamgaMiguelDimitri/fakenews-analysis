# ============================================================
# Fichier  : .env.example
# Rôle     : Template des variables d'environnement
# Projet   : FakeNews Analyzer — DevComplex
# ============================================================
# Copier ce fichier en .env et remplir les valeurs

# ── API ──────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── HuggingFace ──────────────────────────────────────────────
HF_TOKEN=                          # Token HuggingFace (optionnel pour datasets publics)

# ── Kaggle ───────────────────────────────────────────────────
KAGGLE_USERNAME=
KAGGLE_KEY=

# ── Base de données (optionnel) ──────────────────────────────
# DB_TYPE peut être : mongodb | cockroachdb | (vide = mode mock)
DB_TYPE=
MONGODB_URI=mongodb://localhost:27017/fakenews
COCKROACHDB_URI=postgresql://user:pass@host:26257/fakenews?sslmode=verify-full

# ── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Bluesky (V2 streaming) ───────────────────────────────────
BLUESKY_HANDLE=
BLUESKY_PASSWORD=

# ── Kafka (V2 streaming) ─────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_RAW=raw-posts
KAFKA_TOPIC_CLEANED=cleaned-posts
KAFKA_TOPIC_PREDICTIONS=predictions
